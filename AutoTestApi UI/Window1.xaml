<Window x:Class="TestAutomation.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TestAutomation.UI.Wpf.ViewModels"
        xmlns:core="clr-namespace:TestAutomationEngine.Core;assembly=ApiAutoTest"
        xmlns:views="clr-namespace:TestAutomation.UI.Wpf.Views"
        xmlns:editors="clr-namespace:TestAutomation.UI.Wpf.Views.Editors"
        mc:Ignorable="d"
        Title="Test Automation Studio" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <views:ComponentEditorTemplateSelector x:Key="EditorTemplateSelector">
            <views:ComponentEditorTemplateSelector.HttpTemplate>
                <DataTemplate DataType="{x:Type core:HttpStep}">
                    <editors:HttpStepEditor/>
                </DataTemplate>
            </views:ComponentEditorTemplateSelector.HttpTemplate>
            <views:ComponentEditorTemplateSelector.DefaultTemplate>
                <DataTemplate>
                    <TextBlock Text="Select a component to edit" FontSize="16" Foreground="Gray"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </DataTemplate>
            </views:ComponentEditorTemplateSelector.DefaultTemplate>
        </views:ComponentEditorTemplateSelector>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200" MinHeight="100"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <Button Content="Load" Command="{Binding LoadProjectCommand}" />
            <Button Content="Save" Command="{Binding SaveProjectCommand}" />
            <Separator/>
            <Button Content="Run" Command="{Binding RunProjectCommand}" 
                    IsEnabled="{Binding IsProjectLoaded}" Background="Green" Foreground="White"/>
            <Button Content="Stop" Command="{Binding StopRunCommand}" 
                    IsEnabled="{Binding IsRunning}" Background="Red" Foreground="White"/>
            <Separator/>
            <TextBlock Text="Environment:" VerticalAlignment="Center" Margin="5,0,2,0"/>
            <TextBox Text="{Binding Environment, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0,0,10,0"/>
            <CheckBox Content="Run All" IsChecked="{Binding RunAllTestPlans}" VerticalAlignment="Center"/>
        </ToolBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Project Explorer" Grid.Column="0" Margin="5">
                <TreeView ItemsSource="{Binding Project.Children}" x:Name="ProjectTree" 
                          SelectedItemChanged="ProjectTree_SelectedItemChanged">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type core:TestPlan}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋 " FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>

                        <DataTemplate DataType="{x:Type core:HttpStep}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐 " FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type core:GraphQLStep}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊 " FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>

                        <HierarchicalDataTemplate DataType="{x:Type core:Loop}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔁 " FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>

                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#EEE"/>

            <GroupBox Header="Component Editor" Grid.Column="2" Margin="5">
                <ContentControl Content="{Binding SelectedComponent}" 
                                ContentTemplateSelector="{StaticResource EditorTemplateSelector}"/>
            </GroupBox>
        </Grid>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#EEE"/>

        <GroupBox Header="Output" Grid.Row="3" Margin="5">
            <ListBox ItemsSource="{Binding OutputMessages}" Background="Black" Foreground="LightGray"
                     FontFamily="Consolas" FontSize="12">
            </ListBox>
        </GroupBox>

        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar IsIndeterminate="{Binding IsRunning}" Width="100" Height="15" 
                             Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>