<Window x:Class="TestAutomation.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TestAutomation.UI.Wpf.ViewModels"
        xmlns:core="clr-namespace:TestAutomationEngine.Core;assembly=ApiAutoTest"
        xmlns:views="clr-namespace:TestAutomation.UI.Wpf.Views"
        xmlns:editors="clr-namespace:TestAutomation.UI.Wpf.Views.Editors"
        mc:Ignorable="d"
        Title="Test Automation Studio" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=True}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Template Selector for Component Editors -->
        <views:ComponentEditorTemplateSelector x:Key="EditorTemplateSelector">
            <views:ComponentEditorTemplateSelector.HttpTemplate>
                <DataTemplate>
                    <editors:HttpStepEditor />
                </DataTemplate>
            </views:ComponentEditorTemplateSelector.HttpTemplate>
            <views:ComponentEditorTemplateSelector.DefaultTemplate>
                <DataTemplate>
                    <TextBlock Text="Select a component to edit" FontSize="16" Foreground="Gray"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </DataTemplate>
            </views:ComponentEditorTemplateSelector.DefaultTemplate>
        </views:ComponentEditorTemplateSelector>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="200"/>
            <!-- Output panel -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0">
            <!-- Existing Load/Save/Run/Stop buttons -->
            <Button Content="Load" Command="{Binding LoadProjectCommand}" />
            <Button Content="Save" Command="{Binding SaveProjectCommand}" />
            <Separator/>
            <Button Content="Run" Command="{Binding RunProjectCommand}" IsEnabled="{Binding IsProjectLoaded}" Background="Green" Foreground="White"/>
            <Button Content="Stop" Command="{Binding StopRunCommand}" IsEnabled="{Binding IsRunning}" Background="Red" Foreground="White"/>
            <Separator/>
            <Button Content="Add TestPlan" Command="{Binding AddTestPlanCommand}" IsEnabled="{Binding IsProjectLoaded}"/>
            <Menu>
                <MenuItem Header="Add Step">
                    <MenuItem Header="HTTP Request" Command="{Binding AddComponentCommand}" CommandParameter="HttpStep"/>
                    <MenuItem Header="GraphQL Query" Command="{Binding AddComponentCommand}" CommandParameter="GraphQLStep"/>
                    <MenuItem Header="Loop" Command="{Binding AddComponentCommand}" CommandParameter="Loop"/>
                    <MenuItem Header="If Condition" Command="{Binding AddComponentCommand}" CommandParameter="If"/>
                    <MenuItem Header="While Loop" Command="{Binding AddComponentCommand}" CommandParameter="While"/>
                    <MenuItem Header="Script" Command="{Binding AddComponentCommand}" CommandParameter="ScriptStep"/>
                </MenuItem>
            </Menu>
            <Button Content="Delete" Command="{Binding DeleteSelectedComponentCommand}" IsEnabled="{Binding IsProjectLoaded}"/>
            <Separator/>
            <Separator/>
            <TextBlock Text="Environment:" VerticalAlignment="Center" Margin="5,0,2,0"/>
            <TextBox Text="{Binding Environment, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0,0,10,0"/>
            <CheckBox Content="Run All" IsChecked="{Binding RunAllTestPlans}" VerticalAlignment="Center"/>
        </ToolBar>

        <!-- Main Split View -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Project Explorer TreeView -->
            <GroupBox Header="Project Explorer" Grid.Column="0" Margin="5">
                <TreeView ItemsSource="{Binding ProjectRootCollection}" 
                          x:Name="ProjectTree"
                          SelectedItemChanged="ProjectTree_SelectedItemChanged">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type core:Project}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁 " FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                        <!-- TestPlan Template -->
                        <HierarchicalDataTemplate DataType="{x:Type core:TestPlan}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋 " FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                        <!-- HttpStep Template -->
                        <DataTemplate DataType="{x:Type core:HttpStep}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐 " FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                        <!-- GraphQLStep Template -->
                        <DataTemplate DataType="{x:Type core:GraphQLStep}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊 " FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                        <!-- Loop Template (Container) -->
                        <HierarchicalDataTemplate DataType="{x:Type core:Loop}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔁 " FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                        <!-- Add more templates as needed (If, While, Foreach, etc.) -->
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Add TestPlan" Command="{Binding DataContext.AddTestPlanCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <Separator/>
                                        <MenuItem Header="Add HTTP Step" Command="{Binding DataContext.AddComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="HttpStep"/>
                                        <MenuItem Header="Add GraphQL Step" Command="{Binding DataContext.AddComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="GraphQLStep"/>
                                        <MenuItem Header="Add Loop" Command="{Binding DataContext.AddComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Loop"/>
                                        <MenuItem Header="Add If" Command="{Binding DataContext.AddComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="If"/>
                                        <MenuItem Header="Add While" Command="{Binding DataContext.AddComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="While"/>
                                        <MenuItem Header="Add Script" Command="{Binding DataContext.AddComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="ScriptStep"/>
                                        <Separator/>
                                        <MenuItem Header="Delete" Command="{Binding DataContext.DeleteSelectedComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Component Editor Panel -->
            <GroupBox Header="Component Editor" Grid.Column="2" Margin="5">
                <ContentControl Content="{Binding SelectedComponent}" 
                                ContentTemplateSelector="{StaticResource EditorTemplateSelector}"/>
            </GroupBox>
        </Grid>

        <!-- Output Panel -->
        <GroupBox Header="Output" Grid.Row="2" Margin="5">
            <ListBox ItemsSource="{Binding OutputMessages}" 
                     Background="Black" Foreground="LightGray"
                     FontFamily="Consolas" FontSize="12"/>
        </GroupBox>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>