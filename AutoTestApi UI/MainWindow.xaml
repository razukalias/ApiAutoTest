<Window x:Class="TestAutomation.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TestAutomation.UI.Wpf"
        xmlns:vm="clr-namespace:TestAutomation.UI.Wpf.ViewModels"
        xmlns:converters="clr-namespace:TestAutomation.UI.Wpf.Converters"
        xmlns:editors="clr-namespace:TestAutomation.UI.Wpf.Views.Editors"
        Title="Test Automation Studio" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Component editor template selector -->
        <editors:ComponentEditorTemplateSelector x:Key="EditorTemplateSelector">
            <editors:ComponentEditorTemplateSelector.HttpTemplate>
                <DataTemplate DataType="{x:Type core:HttpStep}">
                    <editors:HttpStepEditor />
                </DataTemplate>
            </editors:ComponentEditorTemplateSelector.HttpTemplate>
            <editors:ComponentEditorTemplateSelector.GraphQLTemplate>
                <DataTemplate DataType="{x:Type core:GraphQLStep}">
                    <editors:GraphQLStepEditor />
                </DataTemplate>
            </editors:ComponentEditorTemplateSelector.GraphQLTemplate>
            <editors:ComponentEditorTemplateSelector.ScriptTemplate>
                <DataTemplate DataType="{x:Type core:ScriptStep}">
                    <editors:ScriptStepEditor />
                </DataTemplate>
            </editors:ComponentEditorTemplateSelector.ScriptTemplate>
            <editors:ComponentEditorTemplateSelector.LoopTemplate>
                <DataTemplate DataType="{x:Type core:Loop}">
                    <editors:LoopEditor />
                </DataTemplate>
            </editors:ComponentEditorTemplateSelector.LoopTemplate>
            <!-- Add templates for other component types as needed -->
            <editors:ComponentEditorTemplateSelector.DefaultTemplate>
                <DataTemplate>
                    <TextBlock Text="Select a component to edit" FontSize="16" Foreground="Gray"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </DataTemplate>
            </editors:ComponentEditorTemplateSelector.DefaultTemplate>
        </editors:ComponentEditorTemplateSelector>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Ribbon -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Ribbon (simplified) -->
        <fluent:Ribbon Grid.Row="0" x:Name="MainRibbon">
            <fluent:RibbonTabItem Header="Home">
                <fluent:RibbonGroupBox Header="Project">
                    <fluent:Button Header="New" Command="{Binding NewProjectCommand}" LargeIcon="Images/New.png"/>
                    <fluent:Button Header="Open" Command="{Binding OpenProjectCommand}" LargeIcon="Images/Open.png"/>
                    <fluent:Button Header="Save" Command="{Binding SaveProjectCommand}" LargeIcon="Images/Save.png"/>
                </fluent:RibbonGroupBox>
                <fluent:RibbonGroupBox Header="Execution">
                    <fluent:Button Header="Run" Command="{Binding RunCommand}" LargeIcon="Images/Run.png"
                                   Background="Green" Foreground="White"/>
                    <fluent:Button Header="Stop" Command="{Binding StopCommand}" LargeIcon="Images/Stop.png"/>
                </fluent:RibbonGroupBox>
            </fluent:RibbonTabItem>
        </fluent:Ribbon>

        <!-- Quick Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4">
            <TextBlock Text="Environment:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding Environments}" SelectedItem="{Binding SelectedEnvironment}"
                      DisplayMemberPath="Key" Width="120" Margin="0,0,20,0"/>
            <TextBlock Text="Log Level:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding LogLevels}" SelectedItem="{Binding SelectedLogLevel}" Width="120"/>
            <Button Content="Run" Command="{Binding RunCommand}" Margin="20,0,5,0" Width="60"/>
            <Button Content="Stop" Command="{Binding StopCommand}" Width="60"/>
        </StackPanel>

        <!-- Main Split View -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Project Explorer -->
            <Grid Grid.Column="0" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="PROJECT EXPLORER" FontWeight="Bold" Margin="0,0,0,5"/>
                <TreeView Grid.Row="1" ItemsSource="{Binding Project.Children}" x:Name="ProjectTree"
                          SelectedItemChanged="ProjectTree_SelectedItemChanged">
                    <TreeView.Resources>
                        <!-- Hierarchical templates for each component type -->
                        <HierarchicalDataTemplate DataType="{x:Type core:Project}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/Project.png" Width="16" Height="16"/>
                                <TextBlock Text="{Binding Name}" Margin="4,0"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type core:TestPlan}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/TestPlan.png" Width="16" Height="16"/>
                                <TextBlock Text="{Binding Name}" Margin="4,0"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type core:HttpStep}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/Http.png" Width="16" Height="16"/>
                                <TextBlock Text="{Binding Name}" Margin="4,0"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                        <!-- Add similar templates for Loop, If, While, etc. -->
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Add HttpStep" Command="{Binding DataContext.AddHttpStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <MenuItem Header="Add Loop" Command="{Binding DataContext.AddLoopCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <Separator/>
                                        <MenuItem Header="Run This" Command="{Binding DataContext.RunSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <MenuItem Header="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Component Editor -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="5">
                <ContentControl Content="{Binding SelectedComponent}"
                                ContentTemplateSelector="{StaticResource EditorTemplateSelector}"/>
            </ScrollViewer>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Properties / Toolbox -->
            <TabControl Grid.Column="4" Margin="5">
                <TabItem Header="Properties">
                    <Grid>
                        <TextBlock Text="Properties panel (simplified)" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <!-- You can use a PropertyGrid here -->
                    </Grid>
                </TabItem>
                <TabItem Header="Toolbox">
                    <ItemsControl ItemsSource="{Binding ToolboxItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Command="{Binding DataContext.AddComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" Margin="2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Output Panel -->
        <Grid Grid.Row="3" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TabControl>
                <TabItem Header="Output">
                    <ListBox ItemsSource="{Binding OutputMessages}" Background="Black" Foreground="LightGray"
                             FontFamily="Consolas" FontSize="12"/>
                </TabItem>
                <TabItem Header="Test Results">
                    <TreeView ItemsSource="{Binding ResultTree}">
                        <!-- Similar hierarchical templates with status icons -->
                    </TreeView>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentStep}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>